# Required: Groq API key for AI responses (1> transcribe)
# Get yours at https://console.groq.com/keys
GROQ_API_KEY=<Insert your API Key Here>

# Optional: only needed when running without Docker Compose.
# When using Docker Compose, TRANSCRIBE_URL is set automatically.
# TRANSCRIBE_URL=http://<transcription-server-ip>:8000/transcribe
